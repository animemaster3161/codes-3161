#include <stdio.h>

void bubbleSort(int arr[], int size)
{
    for (int i = 0; i < size; i++)
    {
        int swap = 0; // Added to avoid error
        
        for (int j = 0; j < size - i - 1; j++)
        {
            if (arr[j] > arr[j + 1])
            {
                int temp;
                temp = arr[j];
                arr[j] = arr[j + 1];
                arr[j + 1] = temp;
                swap = 1;
            }
        }
        
        if (!swap)
        {
            break;
        }
    } 
} // Function closed

int main()
{
    int n = 6; // Changed from 5 to 6 because there are 6 elements
    int arr[] = {4, 7, 1, 5, 3, 2};
    
    printf("Array before sorting\n");
    for (int i = 0; i < n; i++)
    {
        printf("%d ", arr[i]);
    }
    
    printf("\n");
    
    bubbleSort(arr, n); // Function call
    
    printf("Array after sorting\n");
    for (int i = 0; i < n; i++)
    {
        printf("%d ", arr[i]);
    }
    
    printf("\nThis is sorted Array now\n");
    
    return 0;
} // End

