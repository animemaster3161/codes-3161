#include <stdio.h>

int main()
{
    int num[20], i, max;
    
    printf("Enter the size of the array: ");
    scanf("%d", &max);
    
    printf("Enter the elements: \n");
    for (i = 0; i < max; i++)
    {
        scanf("%d", &num[i]);
    }
    
    Sort_num(num, max);
    
    printf("Sort number are: \n");
    for(i = 0; i < max; i++)
    {
        printf("%d ", num[i]);
    }
}

// K&R style function definition
void Sort_num(a, n)
int a[], n;
{
    int i, j, temp;
    
    for (i = 0; i < n - 1; i++)
    {
        for (j = i + 1; j < n; j++)
        {
            if (a[i] > a[j])
            {
                temp = a[i];
                a[i] = a[j];
                a[j] = temp;
            }
        }
    }
    return;
}

